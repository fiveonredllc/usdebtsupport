# Copy to .env on the host (or set in docker-compose / Vultr) — do not commit real values.
# Alternatively, set GitHub Actions secrets (same names) — deploy workflow writes them to .env on each push.

# Shared with the browser via /api/client-config.js (visible in DevTools).
LEAD_API_SECRET=generate_a_long_random_string

# Apps Script Web App URL (ends with /exec). Server-side only.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec

# Must match Script property SHEET_SHARED_SECRET in Google Apps Script.
SHEET_SHARED_SECRET=another_long_random_string

# TurboDebt (Acquisition Brands) Host & Post partner token. Server-side only — not exposed to the browser.
TURBODEBT_PARTNER_TOKEN=your_partner_token_here

# Optional: full URL if the site is not served at root (default /api/leads).
# PUBLIC_LEAD_WEBHOOK_URL=/api/leads

# Local only: IP2Location LITE DB9 BIN download token (not used by Node at runtime).
# Copy .env.ip2location.example to .env.ip2location and run: ./scripts/update-ip2location.sh

# Optional: server logs [client-geo] ip2location { ip, region, regionCode } when a US state is resolved.
# Or use ?geo_debug=1 or ?td_debug=1 on the page (browser passes geo_debug to /api/client-geo).
# GEO_DEBUG=0
